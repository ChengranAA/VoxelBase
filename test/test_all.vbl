;; vbl test suite — exercises all built-in ops
;; Run: ./build/vbl-test test/test_all.vbl

;; ── 1. constructors ──────────────────────────────────────────
(print (vol3d 4 4 4 1.0))
(print (vol4d 4 4 4 3 2.0 0.0))
(print (noise 4 4 4 0.5))
(print (affine))

;; ── 2. arithmetic ────────────────────────────────────────────
(print (+ (noise 2 2 2 1.0) (noise 2 2 2 2.0)))
(print (- (noise 2 2 2 1.0) (noise 2 2 2 1.0)))
(print (* (noise 2 2 2 1.0) (noise 2 2 2 1.0)))
(print (/ (noise 2 2 2 2.0) (noise 2 2 2 1.0)))

;; ── 3. broadcast ─────────────────────────────────────────────
(print (bc+ (noise 2 2 2 1.0) (vol3d 1 1 1 3.0)))
(print (bc- (noise 2 2 2 1.0) (vol3d 1 1 1 0.5)))
(print (bc* (noise 2 2 2 1.0) (vol3d 1 1 1 2.0)))
(print (bc/ (noise 2 2 2 1.0) (vol3d 1 1 1 2.0)))

;; ── 4. stats 3D → scalar ─────────────────────────────────────
(def v3 (noise 4 4 4 1.0))
(print (mean v3))
(print (stdev v3))
(print (min v3))
(print (max v3))
(print (sum v3))

;; ── 5. stats 4D → vol3d ──────────────────────────────────────
(def v4 (vol4d 3 3 3 4 1.0 0.0))
(def base (noise 3 3 3 1.0))
(def v4f (bc+ v4 base))
(print (mean v4f))
(print (stdev v4f))
(print (min v4f))
(print (max v4f))
(print (sum v4f))
(print (tmean v4f 0 2))
(print (tstd v4f))

;; ── 6. spatial ───────────────────────────────────────────────
(def a (noise 4 4 4 1.0))
(print (smooth a 1.0))
(print (crop a 1 1 1 2 2 2))
(print (pad a 1 1 1 1 1 1))
(print (threshold a 0.0))

;; ── 7. mask ──────────────────────────────────────────────────
(def msk (threshold a 0.0))
(print (mask a msk))

;; ── 8. data access ───────────────────────────────────────────
(print (slice a 0 1))
(print (slice a 1 1))
(print (slice a 2 1))
(print (tslice v4f 2))
(def seed_ts (seed v4f 0 0 0))
(print (ts-range seed_ts 0 2))
(print (copy a))
(print (voxel a 1 1 1))

;; ── 9. signal ────────────────────────────────────────────────
(def ts (voxel v4f 1 1 1))
(print (detrend ts))
(print (bandpass ts 0.01 0.1))

;; ── 10. comparisons ──────────────────────────────────────────
(def z (vol3d 1 1 1 0))
(def bz (vol3d 1 1 1 999))
(print (eq a a))
(print (gt a z))
(print (lt a bz))
(print (and (gt a z) (lt a bz)))
(print (or (gt a bz) (gt a z)))

;; ── 11. affine ───────────────────────────────────────────────
(print (affine))
(print (translate 1.0 2.0 3.0))
(print (rotate 0 0 1 45.0))
(print (scale 2.0 2.0 2.0))
(def t_aff (* (translate 1 0 0) (scale 2 2 2)))
(print (apply t_aff v3))

;; ── 12. correlate ────────────────────────────────────────────
(print (correlate v4f seed_ts))

;; ── 13. conditional (if) ─────────────────────────────────────
(def one  (vol3d 1 1 1 1.0))
(def zero (vol3d 1 1 1 0.0))
(if (gt one zero) (print one) (print zero))
(if (eq one zero) (print one) (print zero))
(if (and (gt one zero) (lt zero one)) (print one))
(if zero (print one) (print zero))
(if (gt one zero) (print one))

;; ── 14. reserved words ───────────────────────────────────────
(def if   42)
(def mean 42)
(def def  42)

;; ── 15. drift ────────────────────────────────────────────────
(print (drift v4f 1))

;; ── 16. list variables ───────────────────────────────────────
(vars)

;; ── 17. save/load ────────────────────────────────────────────
(save a "build/test_a.nii")
(print (load "build/test_a.nii"))
